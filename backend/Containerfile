# Stage 1 — build dependencies
FROM python:3.12-slim AS builder

WORKDIR /build

# Install build tools
RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir --prefix=/install ".[dev]" 2>/dev/null || pip install --no-cache-dir --prefix=/install .

# Stage 2 — runtime image (OpenShift restricted-v2 compatible)
FROM python:3.12-slim AS runtime

# Non-root, arbitrary-UID safe: chgrp root + g=u so any UID in group 0 works
RUN groupadd -g 1001 forge && useradd -u 1001 -g forge -s /sbin/nologin forge

WORKDIR /app
COPY --from=builder /install /usr/local

COPY . .

# Make app dirs writable by any UID in group 0 (OpenShift assigns random UIDs in root group)
RUN chgrp -R 0 /app && chmod -R g=u /app

# No privileged ports — listen on 8080
EXPOSE 8080

# Drop to non-root
USER 1001

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "1"]
